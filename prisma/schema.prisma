generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

model User {
  id            String         @id @default(cuid())
  clerkUserId   String         @unique
  role          String         @default("user")
  createdAt     DateTime       @default(now())
  conversations Conversation[]
  messages      Message[]
  documents     Document[]
  ingestionLogs IngestionLog[]
}

model Conversation {
  id          String    @id @default(cuid())
  title       String    @default("New Chat")
  domain      String    @default("general")
  clerkUserId String?
  user        User?     @relation(fields: [clerkUserId], references: [clerkUserId])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  messages    Message[]
}

model Message {
  id             String       @id @default(cuid())
  role           String
  content        String
  clerkUserId    String?
  user           User?        @relation(fields: [clerkUserId], references: [clerkUserId])
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
}

model Document {
  id            String         @id @default(cuid())
  title         String
  fileType      String         @default("text")
  status        String         @default("processing")
  domain        String         @default("general")
  uploadedBy    String?
  uploader      User?          @relation(fields: [uploadedBy], references: [clerkUserId])
  createdAt     DateTime       @default(now())
  chunks        DocumentChunk[]
  ingestionLogs IngestionLog[]
}

model DocumentChunk {
  id          String                      @id @default(cuid())
  content     String
  chunkIndex  Int
  totalChunks Int
  embedding   Unsupported("vector(768)")?
  documentId  String
  document    Document                    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime                    @default(now())
}

model IngestionLog {
  id          String   @id @default(cuid())
  adminUserId String
  documentId  String
  status      String
  error       String?
  createdAt   DateTime @default(now())
  admin       User     @relation(fields: [adminUserId], references: [clerkUserId])
  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Lawyer {
  id             Int      @id @default(autoincrement())
  name           String
  specialization String
  experience     String
  location       String
  languages      String[]
  feeRange       String
  rating         Float
  casesHandled   Int
  bio            String
  phone          String
  email          String
  featured       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
